{
  "manifest_version": 3,
  "name": "Phishing Guard",
  "version": "0.1.0",
  "description": "Detects phishing sites while you browse using reputation lookups, local heuristics, and an LLM verdict for unknown sites.",
  "permissions": ["webNavigation", "tabs", "storage", "alarms", "declarativeNetRequest", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Phishing Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["warning/warning.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
