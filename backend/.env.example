# Copy to .env and fill in. The backend reads these at startup.

# OpenAI — powers the LLM verdict tier (Tier 4). Required for zero-day detection.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Safe Browsing — powers the reputation tier (Tier 3). Free.
# https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_KEY=

# Port the proxy listens on (must match BACKEND_URL in extension/config.js).
# On Cloud Run this is injected automatically; leave as-is for local dev.
PORT=8787

# Shared-secret token. When set, every request must send
# "Authorization: Bearer <API_TOKEN>". Set the SAME value as API_TOKEN in
# extension/config.js. Leave empty for open local dev.
API_TOKEN=

# Optional: lock CORS to your extension origin, e.g. chrome-extension://<id>.
# Leave empty to allow any origin (the API token is the real gate).
ALLOWED_ORIGIN=
