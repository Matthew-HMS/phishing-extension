# Copy to .env and fill in. The backend reads these at startup.

# OpenAI — powers the LLM verdict tier (Tier 4). Required for zero-day detection.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Safe Browsing — powers the reputation tier (Tier 3). Free.
# https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_KEY=

# Port the proxy listens on (must match BACKEND_URL in extension/config.js).
PORT=8787
